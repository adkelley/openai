/// Text, image, or file inputs to the model, used to generate a response.
pub type InputOutputParam {
  /// A text input to the model, equivalent to a text input with the user role
  Text(String)
  /// A list of one or many input items to the model, containing different content types.
  Items(List(InputOutput))
}

pub fn encode_io_param(input: InputOutputParam) {
  case input {
    Text(text) -> json.string(text)
    Items(items) -> json.array(items, fn(item) { encode_io_item(item) })
  }
}

pub type InputOutput {
  EasyInputMessage(message.EasyInputMessage)
  /// A message input to the model with a role indicating instruction
  /// following hierarchy. Instructions given with the developer or system
  /// role take precedence over instructions given with the user role.
  MessageItem(message.Message)
  /// An output message from the model.
  ResponseOutputMessageItem(message.ResponseOutputMessage)
  /// The results of a file search tool call.
  FileSearchCallItem(file_search.FileSearchCall)
  /// A tool call to a computer use tool.
  ComputerCallItem(computer.ComputerCallDef)
  /// The output of a computer tool call.
  ComputerCallOutputItem(computer.ComputerCallOutputDef)
  /// The results of a web search tool.
  WebSearchCallItem(web_search.WebSearchCall)
  /// A tool call to run a function.
  FunctionCallItem(function.FunctionCall)
  FunctionCallOutputItem(function.FunctionCallOutput)
  // TODO Write these functions.
  // ToolSearchCall(tool_search.ToolSearchCall)
  // ToolSearchOutput(tool_search.ToolSearchOutput)
  /// A description of the chain of thought used by a /
  /// reasoning model while generating a response. Be sure
  /// to include these items in your input to the
  /// Responses API for subsequent turns of a conversation
  /// if you are manually managing context.
  ReasoningItem(reasoning.ReasoningDef)
  //
  // A description of the chain of thought used by a reasoning model while /
  // generating a response. Be sure to include these items in your input to
  // the Responses API for subsequent turns of a conversation if you are
  // manually managing context.
  ReasoningOutputItem(reasoning.ReasoningOutputDef)
  /// A compaction item generated by the v1/responses/compact API.
  CompactionItem(compaction.Compaction)
  /// An image generation request made by the model.
  ImageGenerationCallItem(image_generation.ImageGenerationCall)
  /// A tool call to run code.
  CodeInterpreterCallItem(code_interpreter.CodeInterpreterCall)
  /// A tool call to run a command on the local shell.
  LocalShellCallItem(shell.LocalShellCall)
  /// The output of a local shell tool call.
  LocalShellCallOutputItem(shell.LocalShellCallOutput)
  /// A tool representing a request to execute one or more shell commands.
  ShellCallItem(shell.ShellCall)
  /// The streamed output items emitted by a shell tool call.
  ShellCallOutputItem(shell.ShellCallOutput)
  /// A tool call representing a request to create, delete, or update files
  /// using diff patches.
  ApplyPatchCallItem(apply_patch.ApplyPatchCall)
  /// The streamed output emitted by an apply patch tool call.
  ApplyPatchCallOutputItem(apply_patch.ApplyPatchCallOutput)
  /// A list of tools available on an MCP server.
  McpListToolsItem(mcp.McpListTools)
  /// A request for human approval of a tool invocation.
  McpApprovalRequestItem(mcp.McpApprovalRequest)
  /// A response to an MCP approval request.
  McpApprovalResponseItem(mcp.McpApprovalResponse)
  /// An invocation of a tool on an MCP server.
  McpCallItem(mcp.McpCall)
  /// The output of a custom tool call from your code, being sent back to the
  /// model.
  CustomToolCallOutputItem(custom.CustomToolCallOutput)
  /// A call to a custom tool created by the model.
  CustomToolCallItem(custom.CustomToolCall)
  ItemReferenceItem(ItemReferenceBody)
}

fn encode_io_item(io_item: InputOutput) -> Json {
  // echo io_item
  // TODO Fill in the rest oio_item these input items.
  case io_item {
    EasyInputMessage(message) -> message.encode_easy_input_message(message)
    MessageItem(message) -> message.encode_message(message)
    ResponseOutputMessageItem(output_message) ->
      message.encode_response_output_message(output_message)
    ReasoningOutputItem(output) -> reasoning.encode_reasoning_output(output)
    FunctionCallItem(call) -> function.encode_function_call(call)
    FunctionCallOutputItem(call_output) ->
      function.encode_function_call_output(call_output)
    WebSearchCallItem(call) -> web_search.encode_web_search_call(call)
    ShellCallItem(call) -> shell.encode_shell_call(call)
    ShellCallOutputItem(call_output) ->
      shell.encode_shell_call_output(call_output)
    _ -> panic as "response.encode_input_item"
  }
}

