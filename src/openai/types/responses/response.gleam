fn decode_response_status() -> Decoder(Status) {
  decode.string
  |> decode.map(fn(status) {
    case status {
      "queued" -> Queued
      "cancelled" -> Cancelled
      "completed" -> Completed
      "failed" -> Failed
      "in_progress" -> InProgress
      "incomplete" -> Incomplete
      _ -> panic as status
    }
  })
}

fn decode_float_like() -> Decoder(Float) {
  decode.one_of(decode.float, or: [decode.int |> decode.map(int.to_float)])
}

fn decode_text() -> Decoder(Option(TextResponseFormatConfiguration)) {
  use format <- decode.optional_field(
    "format",
    None,
    decode.optional(decode_text_response_format_configuration()),
  )
  decode.success(format)
}

fn decode_billing() -> Decoder(Billing) {
  use payer <- decode.field("payer", decode.string)
  decode.success(Billing(payer:))
}

fn decode_input_tokens_details() -> Decoder(InputTokensDetails) {
  use cached_tokens <- decode.field("cached_tokens", decode.int)
  decode.success(InputTokensDetails(cached_tokens:))
}

fn decode_output_tokens_details() -> Decoder(OutputTokensDetails) {
  use reasoning_tokens <- decode.field("reasoning_tokens", decode.int)
  decode.success(OutputTokensDetails(reasoning_tokens:))
}

fn decode_usage() -> Decoder(Usage) {
  use input_tokens <- decode.field("input_tokens", decode.int)
  use input_tokens_details <- decode.field(
    "input_tokens_details",
    decode_input_tokens_details(),
  )
  use output_tokens <- decode.field("output_tokens", decode.int)
  use output_tokens_details <- decode.field(
    "output_tokens_details",
    decode_output_tokens_details(),
  )
  use total_tokens <- decode.field("total_tokens", decode.int)
  decode.success(Usage(
    input_tokens:,
    input_tokens_details:,
    output_tokens:,
    output_tokens_details:,
    total_tokens:,
  ))
}

fn decode_tool() -> Decoder(tool.Tool) {
  use type_ <- decode.field("type", decode.string)
  case type_ {
    "function" -> function.decode_function() |> decode.map(tool.FunctionTool)
    "computer" -> computer.decode_computer() |> decode.map(tool.ComputerTool)
    "computer_use_preview" ->
      computer.decode_computer_use_preview()
      |> decode.map(tool.ComputerUsePreviewTool)
    "web_search" ->
      web_search.decode_web_search() |> decode.map(tool.WebSearchTool)
    "web_search_preview" ->
      web_search_preview.decode_web_search_preview()
      |> decode.map(tool.WebSearchPreviewTool)
    "mcp" -> mcp.decode_mcp() |> decode.map(tool.McpTool)
    "shell" -> shell.decode_shell() |> decode.map(tool.ShellTool)
    "local_shell" ->
      shell.decode_local_shell() |> decode.map(tool.LocalShellTool)
    "apply_patch" -> decode.success(tool.ApplyPatchTool)
    _ -> panic as type_
  }
}

pub fn decode_response() -> Decoder(Response) {
  // echo "decode_response"
  use id <- decode.field("id", decode.string)
  use created_at <- decode.field("created_at", decode.int)
  use error <- decode.field("error", decode.optional(decode_error()))
  use incomplete_details <- decode.field(
    "incomplete_details",
    decode.optional(decode_incomplete_details()),
  )
  use instructions <- decode.field(
    "instructions",
    decode.optional(decode_instructions()),
  )
  use metadata <- decode.field("metadata", decode_metadata())
  use model <- decode.field("model", decode.string)
  use object <- decode.field("object", decode.string)
  use output <- decode.field("output", decode.list(decode_io_item()))
  use parallel_tool_calls <- decode.field("parallel_tool_calls", decode.bool)
  use temperature <- decode.field("temperature", decode.float)
  use tool_choice <- decode.field(
    "tool_choice",
    tool_choice.decode_tool_choice_param(),
  )
  use tools <- decode.field("tools", decode.list(decode_tool()))
  use top_p <- decode.field("top_p", decode.float)
  use background <- decode.field("background", decode.bool)
  use completed_at <- decode.optional_field(
    "completed_at",
    None,
    decode.optional(decode_float_like()),
  )
  use conversation <- decode.optional_field(
    "conversation",
    None,
    decode.optional(decode_conversation()),
  )
  use max_output_tokens <- decode.field(
    "max_output_tokens",
    decode.optional(decode.int),
  )
  use max_tool_calls <- decode.field(
    "max_tool_calls",
    decode.optional(decode.int),
  )
  use output_text <- decode.optional_field(
    "output_text",
    None,
    decode.optional(decode.string),
  )
  use previous_response_id <- decode.field(
    "previous_response_id",
    decode.optional(decode.string),
  )
  use prompt <- decode.optional_field(
    "prompt",
    None,
    decode.optional(decode_prompt()),
  )
  use prompt_cache_key <- decode.field(
    "prompt_cache_key",
    decode.optional(decode.string),
  )
  use prompt_cache_retention <- decode.field(
    "prompt_cache_retention",
    decode.optional(decode.string),
  )
  use reasoning <- decode.field("reasoning", reasoning.decode_reasoning())
  use safety_identifier <- decode.field(
    "safety_identifier",
    decode.optional(decode.string),
  )
  use service_tier <- decode.field("service_tier", decode.string)
  use status <- decode.field("status", decode_response_status())
  use text <- decode.field("text", decode_text())
  use top_logprobs <- decode.field("top_logprobs", decode.int)
  use truncation <- decode.field("truncation", decode.string)
  use billing <- decode.field("billing", decode_billing())
  use store <- decode.field("store", decode.bool)
  use usage <- decode.field("usage", decode.optional(decode_usage()))
  decode.success(Response(
    id:,
    created_at:,
    error:,
    incomplete_details:,
    instructions:,
    metadata:,
    model:,
    object:,
    output:,
    parallel_tool_calls:,
    temperature:,
    tool_choice:,
    tools:,
    top_p:,
    background:,
    completed_at:,
    conversation:,
    max_output_tokens:,
    max_tool_calls:,
    output_text:,
    previous_response_id:,
    prompt:,
    prompt_cache_key:,
    prompt_cache_retention:,
    reasoning:,
    safety_identifier:,
    service_tier:,
    status:,
    text:,
    top_logprobs:,
    truncation:,
    billing:,
    store:,
    usage:,
  ))
}
