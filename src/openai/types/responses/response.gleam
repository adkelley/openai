pub type StreamOptions {
  /// When true, stream obfuscation will be enabled. Stream obfuscation adds
  /// random characters to an obfuscation field on streaming delta events to
  /// normalize payload sizes as a mitigation to certain side-channel attacks.
  /// These obfuscation fields are included by default, but add a small amount
  /// of overhead to the data stream. You can set include_obfuscation to false
  /// to optimize for bandwidth if you trust the network links between your
  /// application and the OpenAI API.
  StreamOptions(include_obfuscation: Bool)
}

fn encode_conversation(conversation: Conversation) -> Json {
  json.object([#("id", json.string(conversation.id))])
}

fn encode_conversation_param(
  conversation_param: ConversationParam(String),
) -> Json {
  case conversation_param {
    ConversationId(id) -> json.string(id)
    Object(conversation) -> encode_conversation(conversation)
  }
}

fn encode_conversation_context(
  conversation_context: Option(ConversationContext),
) -> List(#(String, Json)) {
  case conversation_context {
    Some(ContinuePreviousResponse(id)) -> [
      #("previous_response_id", json.string(id)),
    ]

    Some(ContinueConversation(conversation)) -> [
      #("conversation", encode_conversation_param(conversation)),
    ]

    None -> []
  }
}

fn encode_includable(includable: Includable) -> Json {
  case includable {
    FileSearchCallResults -> "file_search_call.results"
    WebSearchCallResults -> "web_search_call.results"
    WebSearchCallActionSources -> "web_search_call.action.sources"
    MessageInputImageImageUrl -> "message.input_image.image_url"
    ComputerCallOutputOutputImageUrl -> "computer_call_output.output_image_url"
    CodeInterpreterCallOutputs -> "code_interpreter_call.outputs"
    MessageOutputTextLogprobs -> "message.output_text.logprobs"
  }
  |> json.string
}

fn encode_response_prompt_variables(
  response_prompt_variables: ResponsePromptVariables(String),
) -> Json {
  case response_prompt_variables {
    String(value) -> json.string(value)
    Content(content) -> content.encode_content(content)
    Custom(value) -> value
  }
}

fn encode_prompt(prompt: Prompt) -> Json {
  [
    #("id", json.string(prompt.id)),
  ]
  |> helpers.encode_option(
    "variables",
    prompt.variables,
    encode_response_prompt_variables,
  )
  |> json.object
}

fn encode_prompt_cache_retention(
  prompt_cache_retention: PromptCacheRetention,
) -> Json {
  case prompt_cache_retention {
    InMemory -> "in_memory"
    Hours24 -> "24h"
  }
  |> json.string
}

fn encode_service_tier(service_tier: ServiceTier) -> Json {
  case service_tier {
    ServiceTierAuto -> "auto"
    Default -> "default"
    Flex -> "flex"
    Scale -> "scale"
    Priority -> "priority"
  }
  |> json.string
}

fn encode_stream_options(stream_options: StreamOptions) -> Json {
  json.object([
    #("include_obfuscation", json.bool(stream_options.include_obfuscation)),
  ])
}

fn encode_verbosity_value(verbosity: Verbosity) -> Json {
  let _ = verbosity
  panic as "encode_verbosity_value: unsupported value"
}

fn encode_text_response_format_configuration(
  text_response_format_configuration: TextResponseFormatConfiguration,
) -> Json {
  case text_response_format_configuration {
    ResponseFormatText -> json.object([#("type", json.string("text"))])
    ResponseFormatJSONSchemaConfig(name:, schema:) ->
      json.object([
        #("type", json.string("json_schema")),
        #("name", json.string(name)),
        #("schema", schema),
      ])
    ResponseFormatJSONObject ->
      json.object([#("type", json.string("json_object"))])
  }
}

fn encode_text_param(text_param: TextParam) -> Json {
  helpers.encode_option(
    [],
    "verbosity",
    text_param.verbosity,
    encode_verbosity_value,
  )
  |> helpers.encode_option(
    "format",
    text_param.format,
    encode_text_response_format_configuration,
  )
  |> json.object
}

fn encode_truncation_value(truncation: Truncation) -> Json {
  case truncation {
    Auto -> "auto"
    Disabled -> "disabled"
  }
  |> json.string
}

fn encode_metadata(metadata: List(#(String, String))) -> Json {
  json.object(
    list.map(metadata, fn(entry) { #(entry.0, json.string(entry.1)) }),
  )
}

pub type Verbosity {
  Low
  Medium
  High
}

pub type TextResponseFormatConfiguration {
  /// type "text"
  ResponseFormatText
  ResponseFormatJSONSchemaConfig(
    /// The name of the response format. Must be a-z, A-Z, 0-9, or contain
    /// underscores and dashes, with a maximum length of 64.
    name: String,
    /// The schema for the response format, described as a JSON Schema object.
    schema: Json,
    // The type of response format being defined. Always json_schema.
    // type: "json_schema"
  )
  /// type "json_object"
  ResponseFormatJSONObject
}

fn decode_text_response_format_configuration() -> Decoder(
  TextResponseFormatConfiguration,
) {
  use type_ <- decode.field("type", decode.string)
  case type_ {
    "text" -> decode.success(ResponseFormatText)
    "json_object" -> decode.success(ResponseFormatJSONObject)
    "json_schema" -> {
      use name <- decode.field("name", decode.string)
      use _schema <- decode.field("schema", decode.dynamic)
      decode.success(ResponseFormatJSONSchemaConfig(name:, schema: json.null()))
    }
    _ -> panic as type_
  }
}

pub type TextParam {
  TextParam(
    /// An object specifying the format that the model must output.
    format: Option(TextResponseFormatConfiguration),
    /// Constrains the verbosity of the model's response. Lower values will
    /// result in more concise responses, while higher values will result in
    /// more verbose responses.
    verbosity: Option(Verbosity),
  )
}

pub fn new_text_param() -> TextParam {
  TextParam(format: None, verbosity: None)
}

pub fn text_format(
  text_param: TextParam,
  format: TextResponseFormatConfiguration,
) -> TextParam {
  TextParam(..text_param, format: Some(format))
}

pub fn text_verbosity(text_param: TextParam, verbosity: Verbosity) -> TextParam {
  TextParam(..text_param, verbosity: Some(verbosity))
}

pub type TextConfig {
  TextConfig(
    /// An object specifying the format that the model must output.
    format: Option(TextResponseFormatConfiguration),
    /// Constrains the verbosity of the model's response.
    verbosity: Option(Verbosity),
  )
}

fn decode_verbosity() -> Decoder(Verbosity) {
  decode.string
  |> decode.map(fn(verbosity) {
    case verbosity {
      "low" -> Low
      "medium" -> Medium
      "high" -> High
      _ -> panic as verbosity
    }
  })
}

pub fn decode_text_config() -> Decoder(TextConfig) {
  use format <- decode.field(
    "format",
    decode.optional(decode_text_response_format_configuration()),
  )
  use verbosity <- decode.field(
    "verbosity",
    decode.optional(decode_verbosity()),
  )
  decode.success(TextConfig(format:, verbosity:))
}

pub type Truncation {
  Auto
  Disabled
}

pub type CreateResponse {
  CreateResponse(
    /// Whether to run the model in the background
    background: Option(Bool),
    /// Context management configuration for this request.
    context_management: Option(compaction.ContextManagement),
    /// Continue a previous response or continue within a specific conversation.
    conversation_context: Option(ConversationContext),
    /// Specify additional output data to include in the model response.
    include: Option(List(Includable)),
    /// Text, image, or file inputs to the model, used to generate a response
    input: InputOutputParam,
    /// A system (or developer) message inserted into the model's context.
    instructions: Option(String),
    /// When using along with previous_response_id, the instructions from a
    /// previous response will not be carried over to the next response. This
    /// makes it simple to swap out system (or developer) messages in new
    /// responses.
    max_output_tokens: Option(Int),
    /// The maximum number of total calls to built-in tools that can be
    /// processed in a response. This maximum number applies across all built
    /// in tool calls, not per individual tool. Any further attempts to call
    /// a tool by the model will be ignored.
    max_tool_calls: Option(Int),
    /// Set of 16 key-value pairs that can be attached to an object. This can
    /// be useful for storing additional information about the object in a
    /// structured format, and querying for objects via API or the dashboard.
    /// Keys are strings with a maximum length of 64 characters. Values are
    /// strings with a maximum length of 512 characters.
    metadata: Option(List(#(String, String))),
    /// The model to use for generating a response.
    model: String,
    /// Whether to allow the model to run tool calls in parallel.
    parallel_tool_calls: Option(Bool),
    /// The unique ID of the previous response to the model. Use this to
    /// create multi-turn conversations. Learn more about conversation state.
    /// Cannot be used in conjunction with conversation.
    prompt: Option(Prompt),
    /// Used by OpenAI to cache responses for similar requests to optimize
    /// your cache hit rates. Replaces the user field.
    prompt_cache_key: Option(String),
    /// The retention policy for the prompt cache.
    prompt_cache_retention: Option(PromptCacheRetention),
    /// Configuration for reasoning models.
    reasoning: Option(reasoning.ReasoningDef),
    /// A stable identifier used to help detect users of your application /
    /// that may be violating OpenAI's usage policies. The IDs should be a
    /// string that uniquely identifies each user, with a maximum length of
    /// 64 characters. We recommend hashing their username or email address,
    /// in order to avoid sending us any identifying information.
    safety_identifier: Option(String),
    /// Specifies the processing type used for serving the request.
    service_tier: Option(ServiceTier),
    /// Whether to store the generated model response for later retrieval via
    /// API.
    store: Option(Bool),
    /// If set to true, the model response data will be streamed to the
    /// client as it is generated using server-sent events.
    stream: Option(Bool),
    /// Additional configuration for streaming responses.
    stream_options: Option(StreamOptions),
    /// What sampling temperature to use, between 0 and 2.
    temperature: Option(Float),
    /// Configuration options for a text response from the model. Can be plain
    /// text or structured JSON data. Learn more
    text: Option(TextParam),
    /// How the model should select which tool (or tools) to use when
    /// generating a response. See the tools Param
    ///eter to see how to specify
    /// which tools the model can call.
    tool_choice: Option(tool_choice.Param),
    /// An array of tools the model may call while generating a response. You
    /// can specify which tool to use by setting the tool_choice Param
    ///eter.
    tools: Option(List(tool.Tool)),
    /// An integer between 0 and 20 specifying the number of most likely
    /// tokens to return at each token position, each with an associated log
    /// probability. minimum0 maximum20
    top_logprobs: Option(Int),
    /// An alternative to sampling with temperature, called nucleus sampling,
    /// where the model considers the results of the tokens with top_p
    /// probability mass. So 0.1 means only the tokens comprising the top 10%
    /// probability mass are considered.
    /// We generally recommend altering this or temperature but not both.
    /// minimum0 maximum1
    top_p: Option(Float),
    /// The truncation strategy to use for the model response.
    /// auto: If the input to this Response exceeds the model's context
    /// window size, the model will truncate the response to fit the context
    /// window by dropping items from the beginning of the conversation.
    /// disabled (default): If the input size will exceed the context window
    /// size for a model, the request will fail with a 400 error.
    truncation: Option(Truncation),
  )
}

pub fn encode_create_response(create_response: CreateResponse) -> Json {
  helpers.encode_option([], "background", create_response.background, json.bool)
  |> helpers.encode_option(
    "context_management",
    create_response.context_management,
    compaction.encode_context_management,
  )
  |> helpers.encode_option_list(
    "include",
    create_response.include,
    encode_includable,
  )
  |> list.prepend(#("input", encode_io_param(create_response.input)))
  |> helpers.encode_option(
    "instructions",
    create_response.instructions,
    json.string,
  )
  |> helpers.encode_option(
    "max_output_tokens",
    create_response.max_output_tokens,
    json.int,
  )
  |> helpers.encode_option(
    "max_tool_calls",
    create_response.max_tool_calls,
    json.int,
  )
  |> helpers.encode_option(
    "metadata",
    create_response.metadata,
    encode_metadata,
  )
  |> list.prepend(#("model", json.string(create_response.model)))
  |> helpers.encode_option(
    "parallel_tool_calls",
    create_response.parallel_tool_calls,
    json.bool,
  )
  |> helpers.encode_option("prompt", create_response.prompt, encode_prompt)
  |> helpers.encode_option(
    "prompt_cache_key",
    create_response.prompt_cache_key,
    json.string,
  )
  |> helpers.encode_option(
    "prompt_cache_retention",
    create_response.prompt_cache_retention,
    encode_prompt_cache_retention,
  )
  |> helpers.encode_option(
    "reasoning",
    create_response.reasoning,
    reasoning.encode_reasoning,
  )
  |> helpers.encode_option(
    "safety_identifier",
    create_response.safety_identifier,
    json.string,
  )
  |> helpers.encode_option(
    "service_tier",
    create_response.service_tier,
    encode_service_tier,
  )
  |> helpers.encode_option("store", create_response.store, json.bool)
  |> helpers.encode_option("stream", create_response.stream, json.bool)
  |> helpers.encode_option(
    "stream_options",
    create_response.stream_options,
    encode_stream_options,
  )
  |> helpers.encode_option(
    "temperature",
    create_response.temperature,
    json.float,
  )
  |> helpers.encode_option("text", create_response.text, encode_text_param)
  |> helpers.encode_option(
    "tool_choice",
    create_response.tool_choice,
    tool_choice.encode_param,
  )
  |> helpers.encode_option_list(
    "tools",
    create_response.tools,
    tool.encode_tool,
  )
  |> helpers.encode_option(
    "top_logprobs",
    create_response.top_logprobs,
    json.int,
  )
  |> helpers.encode_option("top_p", create_response.top_p, json.float)
  |> helpers.encode_option(
    "truncation",
    create_response.truncation,
    encode_truncation_value,
  )
  |> fn(object) {
    list.append(
      encode_conversation_context(create_response.conversation_context),
      object,
    )
  }
  |> json.object
}

